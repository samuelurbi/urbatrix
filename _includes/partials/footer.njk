{%- set u = page.url -%}
{%- set fIsHome = u == "/" -%}
{%- set fIsProducto = "/producto/" in u -%}
{%- set fIsSol = "/soluciones/" in u -%}
{%- set fIsPrecios = u == "/precios/" -%}
      <footer class="footer">
        <div class="footer-sections">
          <div class="content-6">
            <div class="items">
              <a href="/" aria-label="Urbatrix inicio">
                <img loading="lazy" decoding="async"
                  class="logo-3"
                  src="/assets/logo-6.svg"
                  alt="Urbatrix"
                />
              </a>
              <div class="frame-2">
                <nav class="item" aria-label="Producto">
                  <div class="text-wrapper-30">Producto</div>
                  <a href="/producto/como-funciona/" class="text-wrapper-31">Cómo funciona</a>
                  <a href="/producto/captacion-crm/" class="text-wrapper-32">Captación y CRM</a>
                  <a href="/producto/pago-reservas/" class="text-wrapper-31">Pagos y Reservas</a>
                  <a href="/producto/capa-legal/" class="text-wrapper-31">Capa Legal</a>
                  <a href="/producto/post-venta/" class="text-wrapper-31">Post Venta</a>
                  <a href="/producto/portal-brokers/" class="text-wrapper-31">Portal de Broker</a>
                </nav>
                <nav class="item" aria-label="Company">
                  <div class="text-wrapper-30">Company</div>
                  <a href="/soluciones/para-desarrolladores/" class="text-wrapper-31">Desarrolladores</a>
                  <a href="/soluciones/" class="text-wrapper-31">Brokers y Agencias</a>
                  <a href="/soluciones/para-compradores/" class="text-wrapper-31">Compradores</a>
                  <a href="/casos-exito/" class="text-wrapper-31">Casos de éxito</a>
                </nav>
                <nav class="item" aria-label="Recursos">
                  <div class="text-wrapper-30">Recursos</div>
                  <a href="#" class="text-wrapper-31">Blog</a>
                  <a href="#" class="text-wrapper-32">Guías</a>
                  <a href="#" class="text-wrapper-31">Centro de ayuda</a>
                </nav>
                <address class="item">
                  <div class="text-wrapper-30">Empresa</div>
                  <a href="#" class="text-wrapper-31">Sobre nosotros</a>
                  <a href="/precios/" class="text-wrapper-32">Precios</a>
                  <a href="#" class="text-wrapper-31" data-demo>Solicitar demo</a>
                  <a href="mailto:contacto@urbatrix.com" class="text-wrapper-31"
                    >contacto@urbatrix.com</a
                  >
                </address>
              </div>
            </div>
            <img loading="lazy" decoding="async"
              class="divider"
              src="/assets/divider-1.svg"
              alt=""
              aria-hidden="true"
            />
            <div class="div-3">
              <a href="#" aria-label="Facebook de Urbatrix"
                ><img loading="lazy" decoding="async"
                  class="img-7"
                  src="/assets/facebook-circle-fill-1.svg"
                  alt=""
                  aria-hidden="true"
              /></a>
              <a href="#" aria-label="Instagram de Urbatrix"
                ><img loading="lazy" decoding="async"
                  class="img-7"
                  src="/assets/instagram-fill-1.svg"
                  alt=""
                  aria-hidden="true"
              /></a>
              <a href="#" aria-label="X de Urbatrix"
                ><img loading="lazy" decoding="async"
                  class="img-7"
                  src="/assets/twitter-x-line-1.svg"
                  alt=""
                  aria-hidden="true"
              /></a>
              <p class="text-wrapper-33">
                2026 Urbatrix © Todos los derechos reservados.
              </p>
            </div>
          </div>
          <div class="text-wrapper-34">Urbatrix</div>
        </div>
      </footer>
      <nav class="mobile-bottomnav" aria-label="Navegación móvil">
        <a href="/" class="mbn-link{% if fIsHome %} is-active{% endif %}">Inicio</a>
        <a href="/producto/" class="mbn-link{% if fIsProducto %} is-active{% endif %}">Producto</a>
        <a href="/soluciones/" class="mbn-link{% if fIsSol %} is-active{% endif %}">Soluciones</a>
        <a href="/precios/" class="mbn-link{% if fIsPrecios %} is-active{% endif %}">Precios</a>
        <a href="#" class="mbn-demo" data-demo>Demo</a>
      </nav>
