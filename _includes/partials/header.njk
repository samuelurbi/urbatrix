{# Estado activo del nav según la URL de la página actual #}
{%- set u = page.url -%}
{%- set productoUrls = ["/producto/", "/producto/como-funciona/", "/producto/captacion-crm/", "/producto/pago-reservas/", "/producto/capa-legal/", "/producto/post-venta/", "/producto/portal-brokers/"] -%}
{%- set isProducto = u in productoUrls -%}
{%- set solucionesUrls = ["/soluciones/", "/soluciones/para-desarrolladores/", "/soluciones/para-compradores/"] -%}
{%- set isSoluciones = u in solucionesUrls -%}
{%- set isCasos = "/casos-exito/" in u -%}
{%- set isPrecios = u == "/precios/" -%}
{%- set isHome = u == "/" -%}
      <header class="header">
        <a href="/" class="header-logo" aria-label="Urbatrix inicio">
          <img loading="lazy" decoding="async"
            class="div-left"
            src="/assets/div-left.svg"
            alt="Urbatrix"
          />
          <img
            class="header-iso"
            src="/assets/isotipo-white.svg"
            alt=""
            aria-hidden="true"
          />
        </a>
        <button
          class="mobile-menu-toggle"
          type="button"
          aria-expanded="false"
          aria-controls="mobile-menu"
          aria-label="Abrir menú de navegación"
        >
          <span class="mobile-menu-toggle-icon" aria-hidden="true">
            <span></span>
            <span></span>
            <span></span>
          </span>
        </button>
        <nav class="div-menu-navbar" aria-label="Navegación principal">
          <a href="/" class="navbar-brand" aria-label="Urbatrix inicio">
            <img
              class="navbar-brand-ico"
              src="/assets/isotipo-white.svg"
              alt="Urbatrix"
            />
          </a>
          <span class="navbar-sep" aria-hidden="true"></span>
          <div class="nav-items">
            <a
              href="/"
              class="container-bg-active nav-item"
              aria-label="Inicio"
              {% if isHome %}aria-current="page"{% endif %}
            >
              <div class="icon-home">
                <img loading="lazy" decoding="async"
                  class="img"
                  src="/assets/home-fill-1.svg"
                  alt=""
                  aria-hidden="true"
                />
              </div>
            </a>
            <div class="menu">
            <a
              href="/producto/"
              class="tab nav-item"
              aria-haspopup="true"
              aria-expanded="false"
              data-mega="producto"
              aria-controls="mega-producto"
              {% if isProducto %}aria-current="page"{% endif %}
            >
              <span class="text-wrapper">Producto</span>
              <img loading="lazy" decoding="async"
                class="img"
                src="/assets/arrow-down-s-line-2.svg"
                alt=""
                aria-hidden="true"
              />
            </a>
            <a
              href="/soluciones/"
              class="tab nav-item"
              aria-haspopup="true"
              aria-expanded="false"
              data-mega="soluciones"
              aria-controls="mega-soluciones"
              {% if isSoluciones %}aria-current="page"{% endif %}
            >
              <span class="text-wrapper">Soluciones</span>
              <img loading="lazy" decoding="async"
                class="img"
                src="/assets/arrow-down-s-line-2.svg"
                alt=""
                aria-hidden="true"
              />
            </a>
            <a href="/casos-exito/" class="div-wrapper nav-item"{% if isCasos %} aria-current="page"{% endif %}
              ><span class="text-wrapper">Casos de éxito</span></a
            >
            <a href="/precios/" class="div-wrapper nav-item"{% if isPrecios %} aria-current="page"{% endif %}
              ><span class="text-wrapper">Precios</span></a
            >
            </div>
          </div>
          <span class="navbar-sep" aria-hidden="true"></span>
          <a href="#" class="navbar-demo">Solicitar Demo</a>
        </nav>

        <!-- Mega menú: Producto (3 columnas × 2 filas) -->
          <div
            class="mega-menu mega-menu--producto"
            id="mega-producto"
            role="region"
            aria-label="Producto"
            hidden
          >
            <div class="mega-grid mega-grid--3">
              <a href="/producto/como-funciona/" class="mega-card"{% if u == "/producto/como-funciona/" %} aria-current="page"{% endif %}>
                <div class="mega-card__left">
                  <img class="mega-card__icon" src="/assets/route-fill-1.svg" alt="" aria-hidden="true" />
                </div>
                <div class="mega-card__right">
                  <span class="mega-card__title">Cómo funciona</span>
                  <span class="mega-card__desc">De la inversión en marketing a la entrega de llaves.</span>
                </div>
              </a>
              <a href="/producto/captacion-crm/" class="mega-card"{% if u == "/producto/captacion-crm/" %} aria-current="page"{% endif %}>
                <div class="mega-card__left">
                  <img class="mega-card__icon" src="/assets/megaphone-line-1.svg" alt="" aria-hidden="true" />
                </div>
                <div class="mega-card__right">
                  <span class="mega-card__title">Captación y CRM</span>
                  <span class="mega-card__desc">Cada lead calificado y asignado solo.</span>
                </div>
              </a>
              <a href="/producto/pago-reservas/" class="mega-card"{% if u == "/producto/pago-reservas/" %} aria-current="page"{% endif %}>
                <div class="mega-card__left">
                  <img class="mega-card__icon" src="/assets/bank-card-line-1.svg" alt="" aria-hidden="true" />
                </div>
                <div class="mega-card__right">
                  <span class="mega-card__title">Pagos y Reservas</span>
                  <span class="mega-card__desc">Cobra reservas de cualquier país en minutos.</span>
                </div>
              </a>
              <a href="/producto/capa-legal/" class="mega-card"{% if u == "/producto/capa-legal/" %} aria-current="page"{% endif %}>
                <div class="mega-card__left">
                  <img class="mega-card__icon" src="/assets/shield-user-fill-1.svg" alt="" aria-hidden="true" />
                </div>
                <div class="mega-card__right">
                  <span class="mega-card__title">Capa Legal y Confianza</span>
                  <span class="mega-card__desc">Contratos, CONFOTUR y fideicomiso integrados.</span>
                </div>
              </a>
              <a href="/producto/post-venta/" class="mega-card"{% if u == "/producto/post-venta/" %} aria-current="page"{% endif %}>
                <div class="mega-card__left">
                  <img class="mega-card__icon" src="/assets/key-2-line-1.svg" alt="" aria-hidden="true" />
                </div>
                <div class="mega-card__right">
                  <span class="mega-card__title">Post-venta y Entregas</span>
                  <span class="mega-card__desc">Del cierre a las llaves y la renta.</span>
                </div>
              </a>
              <a href="/producto/portal-brokers/" class="mega-card"{% if u == "/producto/portal-brokers/" %} aria-current="page"{% endif %}>
                <div class="mega-card__left">
                  <img class="mega-card__icon" src="/assets/stackshare-line-5.svg" alt="" aria-hidden="true" />
                </div>
                <div class="mega-card__right">
                  <span class="mega-card__title">Portal de Brokers</span>
                  <span class="mega-card__desc">Tu red vendiendo en la misma dirección.</span>
                </div>
              </a>
            </div>
          </div>

          <!-- Mega menú: Soluciones (2 columnas) -->
          <div
            class="mega-menu mega-menu--soluciones"
            id="mega-soluciones"
            role="region"
            aria-label="Soluciones"
            hidden
          >
            <div class="mega-grid mega-grid--2">
              <a href="/soluciones/para-desarrolladores/" class="mega-card"{% if u == "/soluciones/para-desarrolladores/" %} aria-current="page"{% endif %}>
                <div class="mega-card__left">
                  <img class="mega-card__icon" src="/assets/bank-fill-1.svg" alt="" aria-hidden="true" />
                </div>
                <div class="mega-card__right">
                  <span class="mega-card__title">Para Desarrolladores</span>
                  <span class="mega-card__desc">Urbatrix te da la infraestructura completa de venta que un proyecto de lujo internacional necesita.</span>
                </div>
              </a>
              <a href="/soluciones/para-compradores/" class="mega-card"{% if u == "/soluciones/para-compradores/" %} aria-current="page"{% endif %}>
                <div class="mega-card__left">
                  <img class="mega-card__icon" src="/assets/home-fill-1.svg" alt="" aria-hidden="true" />
                </div>
                <div class="mega-card__right">
                  <span class="mega-card__title">Para Compradores</span>
                  <span class="mega-card__desc">Explora, reserva y firma online. Pagos seguros, contratos bilingües y un asesor real a un clic.</span>
                </div>
              </a>
            </div>
          </div>
        <div class="div-right">
          <a href="https://urbatrix.com" class="a-link-login" target="_blank" rel="noopener"
            ><span class="div">Iniciar Sesión</span></a
          >
          <a href="#" class="a-link-demo"
            ><span class="text-wrapper-2">Solicitar Demo</span></a
          >
        </div>
        <div class="mobile-menu-panel" id="mobile-menu" hidden>
          <nav
            class="mobile-menu-links"
            aria-label="Navegación principal móvil"
          >
            <a href="/" class="mobile-menu-link"{% if isHome %} aria-current="page"{% endif %}>Inicio</a>
            <div class="mobile-menu-group">
              <div class="mobile-menu-prow">
                <a href="/producto/" class="mobile-menu-link mobile-menu-prow__link"{% if isProducto %} aria-current="page"{% endif %}>Producto</a>
                <button
                  class="mobile-menu-parent mobile-menu-prow__chevron"
                  type="button"
                  aria-expanded="false"
                  aria-controls="m-sub-producto"
                  aria-label="Mostrar subpáginas de Producto"
                >
                  <img loading="lazy" decoding="async"
                    class="img"
                    src="/assets/arrow-down-s-line-2.svg"
                    alt=""
                    aria-hidden="true"
                  />
                </button>
              </div>
              <div class="mobile-menu-sub" id="m-sub-producto">
                <a href="/producto/como-funciona/" class="mobile-menu-sublink"{% if u == "/producto/como-funciona/" %} aria-current="page"{% endif %}>Cómo funciona</a>
                <a href="/producto/captacion-crm/" class="mobile-menu-sublink"{% if u == "/producto/captacion-crm/" %} aria-current="page"{% endif %}>Captación y CRM</a>
                <a href="/producto/pago-reservas/" class="mobile-menu-sublink"{% if u == "/producto/pago-reservas/" %} aria-current="page"{% endif %}>Pagos y Reservas</a>
                <a href="/producto/capa-legal/" class="mobile-menu-sublink"{% if u == "/producto/capa-legal/" %} aria-current="page"{% endif %}>Capa Legal y Confianza</a>
                <a href="/producto/post-venta/" class="mobile-menu-sublink"{% if u == "/producto/post-venta/" %} aria-current="page"{% endif %}>Post-venta y Entregas</a>
                <a href="/producto/portal-brokers/" class="mobile-menu-sublink"{% if u == "/producto/portal-brokers/" %} aria-current="page"{% endif %}>Portal de Brokers</a>
              </div>
            </div>
            <div class="mobile-menu-group">
              <div class="mobile-menu-prow">
                <a href="/soluciones/" class="mobile-menu-link mobile-menu-prow__link"{% if isSoluciones %} aria-current="page"{% endif %}>Soluciones</a>
                <button
                  class="mobile-menu-parent mobile-menu-prow__chevron"
                  type="button"
                  aria-expanded="false"
                  aria-controls="m-sub-soluciones"
                  aria-label="Mostrar subpáginas de Soluciones"
                >
                  <img loading="lazy" decoding="async"
                    class="img"
                    src="/assets/arrow-down-s-line-2.svg"
                    alt=""
                    aria-hidden="true"
                  />
                </button>
              </div>
              <div class="mobile-menu-sub" id="m-sub-soluciones">
                <a href="/soluciones/para-desarrolladores/" class="mobile-menu-sublink"{% if u == "/soluciones/para-desarrolladores/" %} aria-current="page"{% endif %}>Para Desarrolladores</a>
                <a href="/soluciones/para-compradores/" class="mobile-menu-sublink"{% if u == "/soluciones/para-compradores/" %} aria-current="page"{% endif %}>Para Compradores</a>
              </div>
            </div>
            <a href="/casos-exito/" class="mobile-menu-link"{% if isCasos %} aria-current="page"{% endif %}>Casos de éxito</a>
            <a href="/precios/" class="mobile-menu-link"{% if isPrecios %} aria-current="page"{% endif %}>Precios</a>
          </nav>
          <div class="mobile-menu-actions">
            <a href="https://urbatrix.com" class="mobile-menu-login" target="_blank" rel="noopener">Iniciar Sesión</a>
            <a href="#" class="mobile-menu-demo">Solicitar Demo</a>
          </div>
        </div>
      </header>
