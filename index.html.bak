                              </div>
                            </div>
                          </div>
                          <img class="ic-vector" src="assets/illus/vector-608.svg" alt="" />
                        </div>
                        <div class="ic-col">
                          <div class="ic-tiktok-wrapper">
                            <img class="ic-img" src="assets/illus/tiktok-1.svg" alt="" />
                          </div>
                          <img class="ic-vector" src="assets/illus/vector-603.svg" alt="" />
                        </div>
                      </div>
                      <div class="ic-panel">
                        <div class="ic-panel-left">
                          <div class="ic-lead">
                            <div class="ic-lead-row">
                              <div class="ic-lead-head">
                                <span class="ic-avatar"><span class="ic-ellipse"></span></span>
                                <p class="ic-step-name">Nuevo Lead</p>
                              </div>
                              <div class="ic-bar"></div>
                            </div>
                            <img class="ic-img-2" src="assets/illus/frame-1000002955.svg" alt="" />
                            <img class="ic-img-2" src="assets/illus/frame-1000002956.svg" alt="" />
                          </div>
                          <div class="ic-add-button">
                            <img class="ic-img-3" src="assets/illus/frame-1000002958.svg" alt="" />
                          </div>
                        </div>
                        <div class="ic-panel-right">
                          <div class="ic-summary">
                            <div class="ic-summary-bars">
                              <div class="ic-bar-2"></div>
                              <div class="ic-bar-3"></div>
                              <div class="ic-bar-4"></div>
                              <div class="ic-bar-5"></div>
                            </div>
                            <div class="ic-toggle-wrap">
                              <div class="ic-toggle">
                                <span class="ic-toggle-divider"></span>
                                <span class="ic-toggle-knob"><span class="ic-knob-dot"></span></span>
                              </div>
                            </div>
