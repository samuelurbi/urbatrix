<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>Urbatrix — Vende tu desarrollo inmobiliario al mundo entero, sin fricción</title>
    <meta
      name="description"
      content="Urbatrix es la plataforma inmobiliaria todo-en-uno: captación y CRM, reservas y pagos (Stripe y WhatsApp), capa legal bilingüe (CONFOTUR, fideicomiso Ley 189-11), seguimiento de obra y post-venta. Todo en una sola plataforma."
    />
    <meta name="theme-color" content="#00b481" />
    <link rel="canonical" href="https://urbatrix.com/" />

    <!-- Favicon -->
    <link rel="icon" type="image/png" sizes="512x512" href="assets/favicon-ubratrix-min.png" />
    <link rel="apple-touch-icon" href="assets/favicon-ubratrix-min.png" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Urbatrix" />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:title" content="Urbatrix — Todo el ciclo de venta inmobiliaria en una sola plataforma" />
    <meta
      property="og:description"
      content="Captación, reservas y pagos, legal bilingüe, seguimiento de obra y post-venta. Vende tu desarrollo inmobiliario al mundo entero, sin fricción."
    />
    <meta property="og:url" content="https://urbatrix.com/" />
    <meta property="og:image" content="assets/dashboard---makai.png" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Urbatrix — Plataforma inmobiliaria todo-en-uno" />
    <meta
      name="twitter:description"
      content="Captación, reservas y pagos, legal bilingüe, seguimiento de obra y post-venta. Todo en una sola plataforma."
    />
    <meta name="twitter:image" content="assets/dashboard---makai.png" />

    <!-- Fuentes (preload de los pesos más usados) -->
    <link rel="preload" href="assets/fonts/MONT-REGULAR.woff" as="font" type="font/woff" crossorigin />
    <link rel="preload" href="assets/fonts/MONT-SEMIBOLD.woff" as="font" type="font/woff" crossorigin />

    <link rel="stylesheet" href="globals.css" />
    <link rel="stylesheet" href="styleguide.css" />
    <link rel="stylesheet" href="style.css" />
    <link rel="stylesheet" href="illustrations.css" />
    <link rel="stylesheet" href="cards.css" />

    <!-- GSAP + ScrollTrigger (CDN) -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js" defer></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js" defer></script>
  </head>
  <body>
    <div class="main-homepage-anima" data-model-id="176:19413">
      <header class="header">
        <a href="#" class="header-logo" aria-label="Urbatrix inicio">
          <img loading="lazy" decoding="async"
            class="div-left"
            src="assets/div-left.svg"
            alt="Urbatrix"
          />
          <img
            class="header-iso"
            src="assets/isotipo-white.svg"
            alt=""
            aria-hidden="true"
          />
        </a>
        <button
          class="mobile-menu-toggle"
          type="button"
          aria-expanded="false"
          aria-controls="mobile-menu"
          aria-label="Abrir menú de navegación"
        >
          <span class="mobile-menu-toggle-icon" aria-hidden="true">
            <span></span>
            <span></span>
            <span></span>
          </span>
        </button>
        <nav class="div-menu-navbar" aria-label="Navegación principal">
          <a href="#" class="navbar-brand" aria-label="Urbatrix inicio">
            <img
              class="navbar-brand-ico"
              src="assets/isotipo-white.svg"
              alt="Urbatrix"
            />
          </a>
          <span class="navbar-sep" aria-hidden="true"></span>
          <div class="nav-items">
            <a
              href="#"
              class="container-bg-active nav-item"
              aria-label="Inicio"
              aria-current="page"
            >
              <div class="icon-home">
                <img loading="lazy" decoding="async"
                  class="img"
                  src="assets/home-fill-1.svg"
                  alt=""
                  aria-hidden="true"
                />
              </div>
            </a>
            <div class="menu">
            <button
              class="tab nav-item"
              type="button"
              aria-haspopup="true"
              aria-expanded="false"
              data-mega="producto"
              aria-controls="mega-producto"
            >
              <span class="text-wrapper">Producto</span>
              <img loading="lazy" decoding="async"
                class="img"
                src="assets/arrow-down-s-line-2.svg"
                alt=""
                aria-hidden="true"
              />
            </button>
            <button
              class="tab nav-item"
              type="button"
              aria-haspopup="true"
              aria-expanded="false"
              data-mega="soluciones"
              aria-controls="mega-soluciones"
            >
              <span class="text-wrapper">Soluciones</span>
              <img loading="lazy" decoding="async"
                class="img"
                src="assets/arrow-down-s-line-2.svg"
                alt=""
                aria-hidden="true"
              />
